{
    "name":  "academic-website-builder",
    "private":  true,
    "version":  "0.1.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "build:pages":  "tsc -b \u0026\u0026 vite build --base=/academic-website-builder/",
                    "preview":  "vite preview",
                    "deploy":  "npm run build:pages \u0026\u0026 gh-pages -d dist"
                },
    "dependencies":  {
                         "@tailwindcss/vite":  "^4.0.0",
                         "@vitejs/plugin-react":  "^4.3.4",
                         "gh-pages":  "^6.3.0",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "tailwindcss":  "^4.0.0",
                         "typescript":  "^5.7.2",
                         "vite":  "^6.0.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^26.0.0",
                            "@types/react":  "^19.2.17",
                            "@types/react-dom":  "^19.2.3"
                        }
}
